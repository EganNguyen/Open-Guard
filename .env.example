# PostgreSQL
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgres://openguard:change-me-in-production@postgres:5432/openguard?sslmode=disable

# JWT Key ring (JSON array, see shared/crypto/jwt.go for format)
# Generate secret with: openssl rand -base64 64
JWT_KEYS=[{"kid":"v1","secret":"REPLACE_ME_WITH_BASE64_SECRET","algorithm":"HS256","status":"active"}]

# AES Encryption Key ring (for MFA secrets)
# Generate key with: openssl rand -base64 32
AES_KEYS=[{"kid":"v1","key":"REPLACE_ME_WITH_BASE64_KEY","status":"active"}]

# Audit HMAC (hash chain integrity)
# Generate with: openssl rand -hex 32
AUDIT_SECRET_KEY=

# MFA Backup Code HMAC
# Generate with: openssl rand -hex 32
IAM_MFA_BACKUP_CODE_HMAC_SECRET=

# SIEM Webhook HMAC
# Generate with: openssl rand -hex 32
ALERTING_SIEM_WEBHOOK_HMAC_SECRET=

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BROKERS=kafka:29092

# Internal API key (service-to-service)
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# Compliance Service
CLICKHOUSE_BULK_FLUSH_ROWS=5000
CLICKHOUSE_BULK_FLUSH_MS=2000
COMPLIANCE_REPORT_MAX_CONCURRENT=10
COMPLIANCE_SIGNING_KEY_PATH=

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=compliance-reports
S3_REGION=us-east-1

# Threat Detection
MAXMIND_LICENSE_KEY=
GEOLITE2_DB_PATH=/data/GeoLite2-City.mmdb
THREAT_MAX_FAILED_LOGINS=11
THREAT_GEO_CHANGE_THRESHOLD_KM=500
THREAT_OFF_HOURS_START=22
THREAT_OFF_HOURS_END=6
