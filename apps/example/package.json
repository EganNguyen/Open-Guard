{
  "name": "@open-guard/example-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch apps/example/server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@open-guard/core": "workspace:*",
    "@open-guard/dashboard": "workspace:*",
    "@open-guard/detectors": "workspace:*",
    "@open-guard/middleware": "workspace:*",
    "@open-guard/sdk": "workspace:*",
    "axios": "^1.15.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "openid-client": "^6.8.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.2",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}