{
  "name": "@open-guard/middleware",
  "version": "1.0.0",
  "description": "Express/Node middleware factory + store adapters",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest"
  },
  "dependencies": {
    "@open-guard/core": "workspace:*",
    "@open-guard/detectors": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4.18"
  },
  "optionalDependencies": {
    "ioredis": "^5.0.0",
    "@upstash/redis": "^1.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "tsup": "^8.0.0",
    "vitest": "^1.0.0"
  }
}